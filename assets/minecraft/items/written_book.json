{
    "model": {
        "type": "minecraft:select",
        "property": "minecraft:custom_model_data",
        "cases": [
            {
                "when": "adv_alarms",
                "model": {
                    "type": "minecraft:model",
                    "model": "blocktech:gui/advancements/alarms"
                }
            },
            {
                "when": "adv_notif",
                "model": {
                    "type": "minecraft:model",
                    "model": "blocktech:gui/advancements/notifications"
                }
            }
        ],
        "fallback": {
            "type": "minecraft:model",
            "model": "minecraft:item/written_book"
        }
    }
}